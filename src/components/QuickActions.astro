---
export interface Props {
  showRSS?: boolean;
  rssURL?: string;
}

const { showRSS = false, rssURL = '/blog/feed.xml' } = Astro.props;
---

<div class="quick-actions" aria-label="Quick settings">
    {showRSS && (
        <a href={rssURL} class="icon-button rss-button" aria-label="RSS Feed" title="Subscribe to RSS feed">
            <svg class="icon icon-rss" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M4 11a9 9 0 0 1 9 9"></path>
                <path d="M4 4a16 16 0 0 1 16 16"></path>
                <circle cx="5" cy="19" r="1"></circle>
            </svg>
        </a>
    )}
    <button id="theme-button" class="icon-button theme-toggle" type="button" aria-label="Switch to light mode" aria-pressed="false">
        <svg class="icon icon-sun" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="12" r="4"></circle>
            <line x1="12" y1="2" x2="12" y2="5"></line>
            <line x1="12" y1="19" x2="12" y2="22"></line>
            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34"></line>
            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"></line>
            <line x1="2" y1="12" x2="5" y2="12"></line>
            <line x1="19" y1="12" x2="22" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66"></line>
            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon icon-moon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M21 12.79A9 9 0 0 1 11.21 3a7 7 0 1 0 8.58 9.79Z"></path>
        </svg>
    </button>
    <button id="accessibility-button" class="icon-button accessibility-toggle" type="button" aria-label="Enable accessibility mode" aria-pressed="false">
        <svg class="icon icon-accessibility" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="5" r="2"></circle>
            <path d="M4 9h16"></path>
            <path d="M12 7v6"></path>
            <path d="M9 21l3-7 3 7"></path>
            <path d="M7 12l5-1 5 1"></path>
        </svg>
    </button>
</div>
