<div class="hamburger-menu">
    <button class="hamburger-icon" popovertarget="menu-popover" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
    </button>
    <div id="menu-popover" class="menu-items" popover>
        <div class="menu-section">
            <label for="theme-select" class="menu-label">Color Scheme</label>
            <select id="theme-select" class="menu-select">
                <option value="nord">Nord</option>
                <option value="mocha">Mocha</option>
                <option value="frappe">Frappe</option>
                <option value="latte">Latte</option>
                <option value="macchiato">Macchiato</option>
                <option value="gruvbox">Gruvbox</option>
                <option value="tokyonight">Tokyo Night</option>
                <option value="monokai">Monokai</option>
                <option value="onedark">One Dark</option>
                <option value="solarized">Solarized</option>
                <option value="kanagawa">Kanagawa</option>
                <option value="pinkie">Pinkie</option>
            </select>
        </div>
        <div class="menu-section">
            <label for="font-select" class="menu-label">Font</label>
            <select id="font-select" class="menu-select">
                <option value="scientifica">Scientifica (Default)</option>
                <option value="pokemon">Pokemon DP Pro</option>
            </select>
        </div>
        <div class="menu-section">
            <label for="font-size-range" class="menu-label">Font Size</label>
            <div class="range-container">
                <input type="range" id="font-size-range" class="menu-range" min="0.8" max="1.4" step="0.1" value="1.1">
                <span id="font-size-value" class="range-value">1.1em</span>
            </div>
        </div>
        <div class="menu-section">
            <label for="blur-intensity-range" class="menu-label">Terminal Blur</label>
            <div class="range-container">
                <input type="range" id="blur-intensity-range" class="menu-range" min="0" max="40" step="2" value="20">
                <span id="blur-intensity-value" class="range-value">20px</span>
            </div>
        </div>
        <button id="background-button">Hide Background</button>
        <button id="transparency-button">Disable Transparency</button>
        <button id="lucky-button">I'm feeling lucky</button>
    </div>
</div>
