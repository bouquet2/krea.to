---
export interface Props {
  command: string;
  hideShell?: boolean;
}

const { command, hideShell = false } = Astro.props;
---

<div class="terminal-section">
    {!hideShell && (
        <div class="prompt"><span class="prompt-user">kreato@akiri:~$</span> <span class="typing-effect">{command}</span></div>
    )}
    <div class="output">
        <slot />
    </div>
</div>
